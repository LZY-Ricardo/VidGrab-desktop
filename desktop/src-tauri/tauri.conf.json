{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VidGrab Desktop",
  "version": "0.1.0",
  "identifier": "top.sunandyu.vidgrab.desktop",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "VidGrab Desktop",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../../resolver"],
    "icon": []
  }
}
